import React, { useState, useEffect } from "react";
import axios from "axios";

const API_URL = "http://15.207.167.232:5000";

const Dashboard = () => {
  const [complaints, setComplaints] = useState([]);

  // Fetch complaints
  useEffect(() => {
    fetchComplaints();
  }, []);

  const fetchComplaints = async () => {
    try {
      const res = await axios.get(`${API_URL}/complaints`);
      setComplaints(res.data);
    } catch (error) {
      console.error("Error fetching complaints:", error);
    }
  };

  // Mark as resolved
  const markResolved = async (id) => {
    try {
      await axios.put(`${API_URL}/complaints/${id}`, {
        status: "Resolved",
      });

      fetchComplaints(); // refresh without reload
    } catch (error) {
      console.error("Error updating status:", error);
    }
  };

  const total = complaints.length;
  const pending = complaints.filter(c => c.status === "Pending").length;
  const resolved = complaints.filter(c => c.status === "Resolved").length;

  return (
    <div className="container">
      <h2>Admin Dashboard</h2>

      {/* Dashboard Cards */}
      <div className="dashboard-cards">
        <div className="card">
          <h3>Total Complaints</h3>
          <p>{total}</p>
        </div>

        <div className="card">
          <h3>Pending</h3>
          <p>{pending}</p>
        </div>

        <div className="card">
          <h3>Resolved</h3>
          <p>{resolved}</p>
        </div>
      </div>

      {/* Complaint Table */}
      <div className="table-container">
        <h3>Complaint List</h3>
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>Name</th>
              <th>Location</th>
              <th>Status</th>
              <th>Image</th>
              <th>Map</th>
              <th>Time</th>
            </tr>
          </thead>
          <tbody>
            {complaints.map((complaint) => (
              <tr key={complaint.id}>
                <td>{complaint.id}</td>
                <td>{complaint.name}</td>
                <td>{complaint.location}</td>
                <td>{complaint.time}</td>

                <td>
                  {complaint.status}
                  {complaint.status === "Pending" && (
                    <button
                      style={{                        marginLeft: "10px",
                        padding: "5px 8px",
                        backgroundColor: "green",
                        color: "white",
                        border: "none",
                        borderRadius: "4px",
                        cursor: "pointer"
                      }}
                      onClick={() => markResolved(complaint.id)}
                    >
                      Resolve
                    </button>
                  )}
                </td>

                {/* Image Column */}
                <td>
                  {complaint.image && (
                    <img
                      src={`${API_URL}/uploads/${complaint.image}`}
                      alt="complaint"
                      width="100"
                    />
                  )}
                </td>

                {/* Google Map Column */}
                <td>
                  {complaint.latitude && complaint.longitude && (
                    <iframe
                      width="200"
                      height="150"
                      style={{ border: 0 }}
                      loading="lazy"
                      allowFullScreen
                      src={`https://www.google.com/maps?q=${complaint.latitude},${complaint.longitude}&output=embed`}
                      title="map"
                    ></iframe>
                  )}
                </td>

              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  );
};

export default Dashboard;
